# ==========================================
# 1. 파이썬 가상환경 및 의존성 (Virtual Environment)
# ==========================================
venv/
.venv/
env/
ENV/
bin/
lib/
include/
share/

# ==========================================
# 2. 파이썬 컴파일 캐시 및 실행 파일 (Python Cache)
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyw
.pytest_cache/
.ipynb_checkpoints/

# ==========================================
# 3. 프로그램 실행 중 생성되는 임시 오디오 및 데이터 (Temporary Media)
# ==========================================
# 프로그램이 마이크 입력을 받아 임시로 기록하는 파일들 제외
# (사용자가 녹음한 클로닝 샘플, STT 임시 파일 등)
temp_input.wav
temp_stt_*.wav
recorded_ref_voice.wav
*.wav
*.mp3
*.flac
*.pcm
*.log

# ==========================================
# 4. AI 모델 가중치 및 대용량 파일 (AI Models / Weights)
# ==========================================
# 만약 프로젝트 폴더 내에 모델을 직접 다운로드하는 경우를 대비
*.pt
*.pth
*.bin
*.ckpt
*.onnx

# ==========================================
# 5. 에디터 및 IDE 설정 파일 (IDE Settings)
# ==========================================
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp

# ==========================================
# 6. 운영체제 시스템 파일 (OS Garbage)
# ==========================================
.DS_Store
.DS_Store?
._*
Thumbs.db
ehthumbs.db
Desktop.ini